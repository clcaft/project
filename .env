# Application
APP_ENV=development
API_PORT=8080
LOG_LEVEL=debug

# Database
DB_HOST=localhost
DB_PORT=3308
DB_USER=procurement_user
DB_PASSWORD=procurement_pass
DB_NAME=procurement_db
DB_ROOT_PASSWORD=root_secret

# Connection Pool
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=10
DB_CONN_MAX_LIFETIME=5m
DB_CONN_MAX_IDLE_TIME=2m